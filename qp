#!/bin/zsh
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SRC="$SCRIPT_DIR/Sources/QuickPhotoObjC/main.m"
BIN="$SCRIPT_DIR/.build/qp"

mkdir -p "$SCRIPT_DIR/.build"

if [[ ! -x "$BIN" || "$SRC" -nt "$BIN" ]]; then
  clang -fobjc-arc \
    "$SRC" \
    -o "$BIN" \
    -framework Foundation \
    -framework AppKit \
    -framework CoreImage \
    -framework CoreMedia \
    -framework CoreVideo \
    -framework AVFoundation
fi

exec "$BIN" "$@"
