#!/bin/zsh
set -euo pipefail

PLIST_PATH="$HOME/Library/LaunchAgents/com.quickphoto.hotkey.plist"
LABEL="com.quickphoto.hotkey"
UID="$(id -u)"

launchctl bootout "gui/$UID" "$PLIST_PATH" >/dev/null 2>&1 || true
launchctl disable "gui/$UID/$LABEL" >/dev/null 2>&1 || true

rm -f "$PLIST_PATH"

echo "Uninstalled QuickPhoto hotkey daemon."
